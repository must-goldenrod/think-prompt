{
  "name": "@pro-prompt/core",
  "version": "0.1.0",
  "description": "Shared core: DB, types, logger, PII, scorer, transcript parser",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./db": {
      "types": "./dist/db.d.ts",
      "import": "./dist/db.js"
    },
    "./transcript": {
      "types": "./dist/transcript/parser.d.ts",
      "import": "./dist/transcript/parser.js"
    }
  },
  "files": ["dist", "migrations"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "typescript": "^6.0.3",
    "tsup": "^8.3.5",
    "vitest": "^4.1.4"
  }
}
