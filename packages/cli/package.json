    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/must-goldenrod/think-prompt/issues"
  },
  "keywords": [
    "claude-code",
    "claude",
    "prompt",
    "prompt-engineering",
    "developer-tool",
    "cli",
    "local-first",
    "privacy",
    "coaching",
    "anthropic"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
