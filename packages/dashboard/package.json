{
  "name": "@pro-prompt/dashboard",
  "version": "0.1.0",
  "description": "Local web dashboard for Pro-Prompt",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pro-prompt-dashboard": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pro-prompt/core": "workspace:*",
    "@pro-prompt/rules": "workspace:*",
    "fastify": "^5.2.0"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "tsup": "^8.3.5",
    "vitest": "^2.1.8"
  }
}
